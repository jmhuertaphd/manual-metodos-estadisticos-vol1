    given-names: "José María"
    orcid: "https://orcid.org/0000-0002-9637-3869"
  - family-names: "Colorado Yohar"
    given-names: "Sandra Milena"
    orcid: "https://orcid.org/0000-0002-6700-0780"
keywords:
  - bioestadística
  - epidemiología
  - inferencia causal
  - análisis de supervivencia
  - meta-análisis
  - R
repository-code: "https://github.com/jmhuertaphd/manual-metodos-estadisticos-vol1"
version: "1.0.0"
date-released: "2026-01-01"
